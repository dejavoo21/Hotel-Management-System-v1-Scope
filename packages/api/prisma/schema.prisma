  fromEmail       String
  subject         String?
  bodyText        String?
  bodyHtml        String?
  attachments     Json?
  messageId       String        @unique
  receivedAt      DateTime
  createdAt       DateTime      @default(now())

  @@index([accessRequestId])
  @@index([receivedAt])
}

// ===========================================
