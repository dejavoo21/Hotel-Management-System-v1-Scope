// ===========================================
// Activity Logging
// ===========================================

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  action    String
  entity    String // e.g., "booking", "room", "guest"
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([bookingId])
  @@index([createdAt])
  @@index([entity, entityId])
}

// ===========================================
// Guest Messaging
// ===========================================

model Conversation {
  id            String             @id @default(cuid())
  hotelId       String
  hotel         Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guestId       String?
  guest         Guest?             @relation(fields: [guestId], references: [id], onDelete: SetNull)
  bookingId     String?
  booking       Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  subject       String?
  status        ConversationStatus @default(OPEN)
  lastMessageAt DateTime?
  messages      Message[]
  ticket        Ticket?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([hotelId])
  @@index([guestId])
  @@index([bookingId])
  @@index([status])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     MessageSender @default(STAFF)
  senderUserId   String?
  senderUser     User?         @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  guestId        String?
  guest          Guest?        @relation("MessageGuest", fields: [guestId], references: [id], onDelete: SetNull)
  body           String
  attachments    Json?
  readAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

enum ConversationStatus {
  OPEN
  RESOLVED
  ARCHIVED
}

enum MessageSender {
  GUEST
  STAFF
  SYSTEM
}

// ===========================================
// Tickets & SLA
// ===========================================

model Ticket {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  type       TicketType     @default(GENERAL_INQUIRY)
  category   TicketCategory @default(OTHER)
  department Department     @default(FRONT_DESK)
  priority   TicketPriority @default(MEDIUM)
  status     TicketStatus   @default(OPEN)

  assignedToId String?
  assignedTo   User?   @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  responseDueAtUtc   DateTime? @map("response_due_at_utc")
  resolutionDueAtUtc DateTime? @map("resolution_due_at_utc")
  firstResponseAtUtc DateTime? @map("first_response_at_utc")
  resolvedAtUtc      DateTime? @map("resolved_at_utc")

  escalatedLevel      Int       @default(0) @map("escalated_level")
  lastEscalationAtUtc DateTime? @map("last_escalation_at_utc")
  sourceKey           String?   @unique @map("source_key")
  details             Json?     @map("details")
  incidentTasks       IncidentTask[]

  createdAtUtc DateTime @default(now()) @map("created_at_utc")
  updatedAtUtc DateTime @updatedAt @map("updated_at_utc")

  @@index([hotelId])
  @@index([status])
  @@index([priority])
  @@index([department])
  @@index([responseDueAtUtc])
  @@index([resolutionDueAtUtc])
  @@map("tickets")
}

// ===========================================
// Incident Management
// ===========================================

model Incident {
  id                String           @id @default(cuid())
  hotelId           String
  hotel             Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  incidentNumber    String
  title             String
  description       String?
  category          IncidentCategory
  severity          IncidentSeverity @default(MEDIUM)
  status            IncidentStatus   @default(NEW)
  sourceModule      String
  linkedEntityType  String?
  linkedEntityId    String?
  createdById       String?
  createdBy         User?            @relation("IncidentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignedManagerId String?
  assignedManager   User?            @relation("IncidentAssignedManager", fields: [assignedManagerId], references: [id], onDelete: SetNull)
  startedAt         DateTime         @default(now())
  resolvedAt        DateTime?
  closedAt          DateTime?
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  tasks             IncidentTask[]
  comments          IncidentComment[]
  attachments       IncidentAttachment[]

  @@unique([hotelId, incidentNumber])
  @@index([hotelId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([sourceModule])
  @@index([linkedEntityType, linkedEntityId])
  @@index([startedAt])
}

model IncidentTask {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([incidentId, ticketId])
  @@index([ticketId])
}

model IncidentComment {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  hotelId    String
  hotel      Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body       String
  createdAt  DateTime @default(now())

  @@index([incidentId])
  @@index([hotelId])
  @@index([createdAt])
}

model IncidentAttachment {
  id           String   @id @default(cuid())
  incidentId   String
  incident     Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  hotelId      String
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  filename     String
  url          String
  contentType  String?
  sizeBytes    Int?
  createdAt    DateTime @default(now())

  @@index([incidentId])
  @@index([hotelId])
}

enum IncidentCategory {
  SECURITY
  MAINTENANCE
  SMART_BUILDING
  OPERATIONS
  WEATHER
  HOUSEKEEPING
  IT
  GUEST
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  NEW
  ACKNOWLEDGED
  INVESTIGATING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SLAPolicy {
  id      String @id @default(cuid())
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  category            TicketCategory
  department          Department
  responseMinutes     Int
  resolutionMinutes   Int
  escalationStepsJson Json           @map("escalation_steps_json")
  isActive            Boolean        @default(true)

  createdAtUtc DateTime @default(now()) @map("created_at_utc")

  @@unique([hotelId, category, department])
  @@index([hotelId])
  @@map("sla_policies")
}

enum TicketType {
  BOOKING_RELATED
  GENERAL_INQUIRY
}

enum TicketStatus {
  OPEN
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
  BREACHED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Department {
  FRONT_DESK
  HOUSEKEEPING
  MAINTENANCE
  CONCIERGE
  BILLING
  MANAGEMENT
}

enum TicketCategory {
  COMPLAINT
  BILLING
  HOUSEKEEPING
  MAINTENANCE
  CONCIERGE
  ROOM_SERVICE
  CHECK_IN_OUT
  BOOKING
  OTHER
}

// ===========================================
// Notifications
// ===========================================

model Notification {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotelId String
  hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  type   NotificationType
  title  String
  body   String
  isRead Boolean          @default(false)
  readAt DateTime?

  // Optional link to ticket that triggered the notification
  ticketId       String?
  conversationId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([hotelId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationType {
  TICKET_ASSIGNED
  TICKET_ESCALATED
  TICKET_BREACHED
  TICKET_UPDATED
  TICKET_RESOLVED
  MESSAGE_RECEIVED
  SYSTEM
}

// ===========================================
// Inventory
// ===========================================

model InventoryItem {
  id                 String              @id @default(cuid())
  hotelId            String
  hotel              Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name               String
  category           String
  unit               String
  quantityOnHand     Int                 @default(0)
  reorderPoint       Int                 @default(0)
  cost               Decimal             @default(0) @db.Decimal(10, 2)
  location           String?
  isActive           Boolean             @default(true)
  purchaseOrderItems PurchaseOrderItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([hotelId])
  @@index([category])
  @@index([isActive])
}

// ===========================================
// Purchase Orders
// ===========================================

model PurchaseOrder {
  id            String              @id @default(cuid())
  hotelId       String
  hotel         Hotel               @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  requestedById String?
  requestedBy   User?               @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  reference     String              @unique
  vendorName    String
  vendorEmail   String?
  status        PurchaseOrderStatus @default(DRAFT)
  notes         String?
  totalCost     Decimal             @default(0) @db.Decimal(10, 2)
  items         PurchaseOrderItem[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([hotelId])
  @@index([status])
  @@index([reference])
}

model PurchaseOrderItem {
  id              String         @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  name            String
  unit            String
  quantity        Int
  unitCost        Decimal        @db.Decimal(10, 2)
  totalCost       Decimal        @db.Decimal(10, 2)
  createdAt       DateTime       @default(now())

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  APPROVED
  RECEIVED
  CANCELLED
}

// ===========================================
// Auth & Access Requests
// ===========================================

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailOtp {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  purpose   String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model AccessRequest {
  id          String               @id @default(cuid())
  fullName    String
  email       String
  company     String?
  role        String?
  message     String?
  adminNotes  String?
  lastReplyAt DateTime?
  status      AccessRequestStatus  @default(PENDING)
